{
    "openComposedOutput": true,

    "deployment": {
        "enabled": true,
        "github": {
            "enabled": true,
            "owner": "biggaboy212",
            "repo": "Cascade"
        }
    },

    "testing": {
        "enabled": true,
        "inputDir": "tests",
        "outputDir": "generated/tests",
        "frame": "pipeline/frames/stable.luau",
        "darkluaConfig": "pipeline/darklua/unminified.json"
    },

    "buildConfigs": [
        {
            "name": "Debug",

            "promptVersion": false,
            "promptDeploy": false,

            "frame": "pipeline/frames/stable.luau",
            "darkluaConfig": "pipeline/darklua/unminified.json",
            "input": "src/main.luau",
            "output": "generated/debug/dist.luau"
        },

        {
            "name": "Beta",

            "promptVersion": true,
            "promptDeploy": true,
            "prerelease": true,

            "frame": "pipeline/frames/stable.luau",
            "darkluaConfig": "pipeline/darklua/stable.json",
            "input": "src/main.luau",
            "output": "generated/beta/dist.luau",
            "variants": [
                {
                    "name": "Typed",
                    "darkluaConfig": "pipeline/darklua/typed.json",
                    "output": "generated/beta/dist-typed.luau"
                },
                {
                    "name": "Unminified",
                    "darkluaConfig": "pipeline/darklua/unminified.json",
                    "output": "generated/beta/dist-unminified.luau"
                }
            ]
        },

        {
            "name": "Release",
            
            "promptVersion": true,
            "promptDeploy": true,

            "frame": "pipeline/frames/stable.luau",
            "darkluaConfig": "pipeline/darklua/stable.json",
            "input": "src/main.luau",
            "output": "generated/release/dist.luau",
            "variants": [
                {
                    "name": "Typed",
                    "darkluaConfig": "pipeline/darklua/typed.json",
                    "output": "generated/beta/dist-typed.luau"
                },
                {
                    "name": "Unminified",
                    "darkluaConfig": "pipeline/darklua/unminified.json",
                    "output": "generated/release/dist-unminified.luau"
                }
            ]
        }
  ]
}